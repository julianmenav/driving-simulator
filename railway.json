{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'No build step — the server runs from TypeScript via tsx.'"
  },
  "deploy": {
    "startCommand": "npm start -w @driving-sim/server",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
