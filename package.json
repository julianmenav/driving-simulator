{
  "name": "driving-simulator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @driving-sim/client",
    "build": "npm run build -w @driving-sim/client",
    "preview": "npm run preview -w @driving-sim/client",
    "deploy": "npm run deploy -w @driving-sim/client",
    "server": "npm run dev -w @driving-sim/server",
    "test": "npm test --workspaces --if-present",
    "test:watch": "npm run test:watch -w @driving-sim/shared"
  }
}
