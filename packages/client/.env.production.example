# Production build (GitHub Pages) — copy to `.env.production` and fill in.
#
# Pages is served over HTTPS, so the WebSocket MUST be wss:// (a ws:// URL is
# blocked as mixed content). Point it at your deployed Railway server's domain.
# The LAN auto-derive does NOT apply on Pages (it would resolve to github.io),
# so this MUST be set explicitly for the deployed frontend.
VITE_SERVER_URL=wss://your-app.up.railway.app
